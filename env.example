# GitHub Configuration
# Create a Classic PAT at https://github.com/settings/tokens with 'repo' scope
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repository_name

# Database Configuration
POSTGRES_DB=cicd_dashboard
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=postgres-service
POSTGRES_PORT=5432

# Application Configuration
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Email Alert Configuration (optional — leave blank to disable)
# For Gmail: enable 2FA and use an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=alerts_recipient@example.com
